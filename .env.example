# Copy to .env and fill in real values. Never commit the filled-in file.

# --- signal_server.py (Doubleword/Nemotron client) ---
DOUBLEWORD_API_KEY=your_doubleword_api_key_here
DOUBLEWORD_BASE_URL=https://api.doubleword.ai/v1/
DOUBLEWORD_MODEL=nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-NVFP4

# --- macro_agent/advisory/claude_analyst.py + macro_agent/dashboard/app.py ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
NEWS_API_KEY=your_newsapi_key_here_optional

# --- trading_engine/mt5_executor.py + ops/connect_test.py (MT5 execution) ---
MT5_LOGIN=your_mt5_account_number_here
MT5_SERVER=your_mt5_server_host:port_here
MT5_PASSWORD=your_mt5_password_here

# --- trading_engine/ops/pinger.py + leaderboard_pinger.py (Telegram alerts) ---
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- trading_engine/ops/leaderboard_pinger.py (Syphonix leaderboard API) ---
# Short-lived Cognito bearer token — paste a fresh one when you want a read, don't store long-term.
SYPHONIX_TOKEN=your_short_lived_syphonix_bearer_token_here
